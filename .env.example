# UniRed Backend environment template

# Supabase DB password
DB_PASSWORD=replace_with_your_db_password

# Base64 secret for JWT (recommended: 64 random bytes encoded in Base64)
JWT_SECRET=replace_with_base64_secret

# Firebase (optional in local)
FIREBASE_ENABLED=false
FIREBASE_CREDENTIALS_PATH=classpath:firebase-service-account.json

# Gmail SMTP (REQUIRED for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tuemail@gmail.com
SMTP_PASSWORD=app_password_de_16_caracteres
